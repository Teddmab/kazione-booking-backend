    "@fullcalendar/timegrid": "^6.1.20",
    "@hookform/devtools": "^4.4.0",
    "@sentry/node": "^10.48.0",
    "@sentry/react": "^10.48.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "date-fns-tz": "^3.2.0",
    "posthog-js": "^1.367.0",
    "resend": "^6.10.0",
    "stripe": "^22.0.1"
