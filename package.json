{
  "name": "kazione-booking-be",
  "version": "1.0.0",
  "description": "KaziOne Booking Backend – Supabase Edge Functions & Migrations",
  "scripts": {
    "start": "npx supabase start",
    "stop": "npx supabase stop",
    "dev": "npx supabase functions serve --env-file .env",
    "dev:remote": "npx supabase functions serve --project-ref hwvqbsqlvwvedyhfuiwt --no-verify-jwt --env-file .env",
    "functions:serve": "npx supabase functions serve --env-file .env",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "lint": "deno lint supabase/functions",
    "test:backend": "deno test supabase/functions/ --allow-env --allow-net --allow-read"
  },
